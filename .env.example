# ═══════════════════════════════════════════════════════
# ShadowNet — Production Environment Configuration
# ═══════════════════════════════════════════════════════
# Copy to .env before deploying. All SHADOWNET_* variables
# are read by the backend at startup. VITE_* variables are
# consumed at frontend build time (Vite).

# ── Database ──────────────────────────────────────────
# SQLite (local dev):
#   SHADOWNET_DATABASE_URL=sqlite+aiosqlite:///data/shadownet.db
#
# PostgreSQL (Railway — auto-provided as DATABASE_URL):
#   The backend auto-converts postgresql:// → postgresql+asyncpg://
SHADOWNET_DATABASE_URL=sqlite+aiosqlite:///data/shadownet.db

# ── AI / Ollama ──────────────────────────────────────
# Set SHADOWNET_DEMO_MODE=true when no Ollama is available.
# The application remains fully functional with synthetic analyses.
SHADOWNET_DEMO_MODE=false
# SHADOWNET_OLLAMA_ENDPOINT=http://ollama:11434
# SHADOWNET_OLLAMA_MODEL=phi3:mini

# ── CORS ──────────────────────────────────────────────
# Comma-separated origins or * for development.
# In production, set to your frontend URL:
#   SHADOWNET_CORS_ORIGINS=https://your-app.vercel.app
SHADOWNET_CORS_ORIGINS=*

# ── Logging ───────────────────────────────────────────
# Options: DEBUG, INFO, WARN, ERROR
SHADOWNET_LOG_LEVEL=INFO

# ── Debug ─────────────────────────────────────────────
# Enables SQL echo and verbose error messages.
SHADOWNET_DEBUG=false

# ── Sync ──────────────────────────────────────────────
SHADOWNET_SYNC_INTERVAL_SECONDS=60
SHADOWNET_MAX_SYNC_RETRIES=5

# ── Security ──────────────────────────────────────────
# Change this in production to a random secret.
# SHADOWNET_SECRET_KEY=change-me-to-a-random-secret

# ── Frontend (Vite) — set on Vercel ──────────────────
# VITE_API_URL=https://your-backend.up.railway.app
# VITE_WS_URL=wss://your-backend.up.railway.app/api/ws
# Optional Stadia Maps API key — when unset, falls back to free OSM tiles
# VITE_STADIA_KEY=
